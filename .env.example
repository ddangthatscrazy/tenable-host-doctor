# LLM Configuration (for AI agent)
# The agent will use deterministic fallback if not configured

# Anthropic (recommended)
SCAN_DOCTOR_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# SCAN_DOCTOR_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-your-key-here

# Ollama (local, free)
# SCAN_DOCTOR_MODEL=ollama/llama3.1
# SCAN_DOCTOR_API_BASE=http://localhost:11434

# Tenable API (only needed for scan creation)
# Not required for analysis - only if you want to create diagnostic scans via API
# TIO_ACCESS_KEY=your-tenable-access-key
# TIO_SECRET_KEY=your-tenable-secret-key

# Agent Settings (optional)
# AGENT_MAX_ITERATIONS=15
# AGENT_VERBOSE=false
